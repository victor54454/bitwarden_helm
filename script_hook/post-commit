#!/bin/bash
# post-commit hook : push auto avec choix de branche + création si nécessaire

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

echo "Commit créé sur la branche locale : $CURRENT_BRANCH"

exec < /dev/tty

read -p "Voulez-vous pousser sur cette branche ($CURRENT_BRANCH) ? [O/n] " choice

exec <&-

case "$choice" in
  [nN]*)
    exec < /dev/tty
    read -p "Entrez le nom de la branche sur laquelle pousser : " TARGET_BRANCH
    exec <&-
    ;;
  *)
    TARGET_BRANCH=$CURRENT_BRANCH
    ;;
esac

if ! git rev-parse --verify "$TARGET_BRANCH" >/dev/null 2>&1; then
    echo "La branche '$TARGET_BRANCH' n'existe pas en local. Création..."
    git checkout -b "$TARGET_BRANCH"
fi

echo "Push vers origin/$TARGET_BRANCH..."
git push -u origin "$TARGET_BRANCH"

if [ $? -eq 0 ]; then
    echo "Push réussi vers origin/$TARGET_BRANCH"
else
    echo "Erreur lors du push vers origin/$TARGET_BRANCH"
    exit 1
fi
